# PostgreSQL
POSTGRES_USER=redump
POSTGRES_PASSWORD=changeme
POSTGRES_DB=redump

# Application
DATABASE_URL=postgres://redump:changeme@postgres:5432/redump
APP_SECRET_KEY=generate-a-random-64-char-hex-string
APP_BASE_URL=http://localhost:8080
APP_PORT=3000

# SMTP (for email verification and password reset)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=noreply@redump.org
SMTP_PASSWORD=changeme
SMTP_FROM=noreply@redump.org

# OIDC Provider
OIDC_ISSUER_URL=http://localhost:8080
OIDC_SIGNING_KEY=generate-a-random-rsa-key

# Domain (for Caddy)
DOMAIN=localhost
