# PostgreSQL
POSTGRES_USER=vgindex
POSTGRES_PASSWORD=changeme
POSTGRES_DB=vgindex

# Application
DATABASE_URL=postgres://vgindex:changeme@postgres:5432/vgindex
APP_SECRET_KEY=generate-a-random-64-char-hex-string
APP_BASE_URL=http://localhost:8080
APP_PORT=3000

# SMTP (for email verification and password reset)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=noreply@vgindex.org
SMTP_PASSWORD=changeme
SMTP_FROM=noreply@vgindex.org

# OIDC Provider
OIDC_ISSUER_URL=http://localhost:8080
OIDC_SIGNING_KEY=generate-a-random-rsa-key

# Domain (for Caddy)
DOMAIN=localhost
