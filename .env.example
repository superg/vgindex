# Site configuration
#
# Local setup:
# Add this line to /etc/hosts:
# 127.0.0.1 redump.test www.redump.test forum.redump.test wiki.redump.test
#
# Production setup:
# Use real HTTPS URLs and set SITE_PORT_HTTP=80 / SITE_PORT_HTTPS=443.
SITE_HOST=redump.test
SITE_PORT_HTTP=18000
SITE_PORT_HTTPS=18443
SITE_ADMIN_EMAIL=admin@${SITE_HOST}
SITE_APEX_URL=http://${SITE_HOST}:${SITE_PORT_HTTP}
APP_PUBLIC_URL=http://${SITE_HOST}:${SITE_PORT_HTTP}
APP_WWW_URL=http://www.${SITE_HOST}:${SITE_PORT_HTTP}
PHPBB_PUBLIC_URL=http://forum.${SITE_HOST}:${SITE_PORT_HTTP}
MEDIAWIKI_PUBLIC_URL=http://wiki.${SITE_HOST}:${SITE_PORT_HTTP}
OIDC_PROVIDER_URL=${PHPBB_PUBLIC_URL}/app.php/oidc

# Direct browser/debug URLs bypass Caddy:
# Production can omit these unless the default localhost-only ports collide.
APP_DIRECT_PORT=18080
PHPBB_DIRECT_PORT=18081
MEDIAWIKI_DIRECT_PORT=18082
POSTGRES_DIRECT_PORT=15432

CADDY_HTTP_PORT=${SITE_PORT_HTTP}
CADDY_HTTPS_PORT=${SITE_PORT_HTTPS}
# This is the full Caddy global option line injected into the Caddyfile.
# Keep the literal "email " prefix.
CADDY_ACME_EMAIL="email admin@redump.test"

# SMTP mail relay
SMTP_HOST=smtp.example.com
SMTP_PORT=587
# Leave SMTP_USER/SMTP_PASSWORD blank for IP-authenticated relay providers.
SMTP_USER=changeme-smtp-user
SMTP_PASSWORD=changeme-smtp-password
SMTP_FROM=noreply@${SITE_HOST}
SMTP_FROM_NAME=VGIndex

# Docker images (override for production with GHCR paths)
# APP_IMAGE=ghcr.io/<org>/app
# PHPBB_IMAGE=ghcr.io/<org>/phpbb
# MEDIAWIKI_IMAGE=ghcr.io/<org>/mediawiki
# IMAGE_TAG=sha-abc1234
APP_IMAGE=app
PHPBB_IMAGE=phpbb
MEDIAWIKI_IMAGE=mediawiki
IMAGE_TAG=dev

# PostgreSQL
# Host/cargo-run connection to Postgres.
POSTGRES_HOST=127.0.0.1
POSTGRES_DB=myapp
POSTGRES_USER=admin
# openssl rand -base64 24
POSTGRES_PASSWORD=changeme-postgres

# Application
APP_UPSTREAM_HOST=app
APP_PORT=3000
# For cargo-run app debugging:
# APP_UPSTREAM_HOST=host.docker.internal docker compose up -d --scale app=0
# cargo run
#
# If UFW is active with default incoming traffic denied, Caddy may not be able
# to reach the host-run app. Allow the Compose network to the app port:
# docker network inspect -f '{{(index .IPAM.Config 0).Subnet}}' vgindex_default
# sudo ufw allow from <subnet> to any port 3000 proto tcp comment 'Allow vgindex Caddy to host cargo app'
APP_OIDC_CLIENT_ID=vgindex-app
# openssl rand -base64 24
APP_OIDC_CLIENT_SECRET=changeme-app-oidc

# phpBB
PHPBB_TABLE_PREFIX=phpbb_
PHPBB_ADMIN_USER=admin
# openssl rand -base64 21  (phpBB max 30 chars)
PHPBB_ADMIN_PASSWORD=changeme-phpbb
PHPBB_ADMIN_EMAIL=${SITE_ADMIN_EMAIL}
PHPBB_BOARD_NAME="${SITE_HOST} Forum"
PHPBB_BOARD_DESCRIPTION="Disc Preservation Community"
# Bootstrap-only defaults, applied on fresh phpBB install or when forced.
PHPBB_BOOTSTRAP_MODE=auto
PHPBB_REQUIRE_ACTIVATION=3
PHPBB_ALLOW_PASSWORD_RESET=true
PHPBB_FEED_ENABLE=true
PHPBB_FEED_LIMIT_TOPIC=5
PHPBB_EMAIL_ENABLE=false
PHPBB_BOARD_EMAIL=${SMTP_FROM}
PHPBB_CONTACT_EMAIL=${SMTP_FROM}
PHPBB_SMTP_HOST=${SMTP_HOST}
PHPBB_SMTP_PORT=${SMTP_PORT}
PHPBB_SMTP_USER=${SMTP_USER}
PHPBB_SMTP_PASSWORD=${SMTP_PASSWORD}
# Ignored when PHPBB_SMTP_USER/PHPBB_SMTP_PASSWORD are blank.
PHPBB_SMTP_AUTH_METHOD=PLAIN
PHPBB_SMTP_SECURE=

# MediaWiki
MEDIAWIKI_ADMIN_USER=admin
# openssl rand -base64 24
MEDIAWIKI_ADMIN_PASSWORD=changeme-mediawiki
# 64-char hex string (openssl rand -hex 32)
MEDIAWIKI_SECRET_KEY=00112233445566778899aabbccddeeff00112233445566778899aabbccddeeff
# 16-char hex string (openssl rand -hex 8)
MEDIAWIKI_UPGRADE_KEY=0011223344556677
MEDIAWIKI_OIDC_CLIENT_ID=mediawiki-client
# openssl rand -base64 24
MEDIAWIKI_OIDC_CLIENT_SECRET=changeme-mediawiki-oidc
MEDIAWIKI_OIDC_VERIFY_TLS=true
MEDIAWIKI_LOCAL_LOGIN=false
MEDIAWIKI_EMAIL_ENABLE=false
MEDIAWIKI_EMAIL_FROM=${SMTP_FROM}
MEDIAWIKI_EMAIL_FROM_NAME=${SMTP_FROM_NAME}
MEDIAWIKI_SMTP_HOST=${SMTP_HOST}
MEDIAWIKI_SMTP_PORT=${SMTP_PORT}
MEDIAWIKI_SMTP_USER=${SMTP_USER}
MEDIAWIKI_SMTP_PASSWORD=${SMTP_PASSWORD}
# Defaults to true for bare SMTP hosts and false for ssl:// or tls:// hosts.
MEDIAWIKI_SMTP_STARTTLS=

# Direct debug ports bind to loopback so production hosts do not expose them publicly.
DIRECT_BIND_ADDR=127.0.0.1
