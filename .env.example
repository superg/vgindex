# Site configuration
DOMAIN=localhost
HTTPS_PORT=8443
HTTP_PORT=8080
# TLS cert email — enables ZeroSSL fallback if Let's Encrypt is rate-limited.
# Leave empty for local dev. Production: CADDY_ACME_EMAIL=email your@email.com
CADDY_ACME_EMAIL=

# Docker images (override for production with GHCR paths)
# APP_IMAGE=ghcr.io/<org>/app
# PHPBB_IMAGE=ghcr.io/<org>/phpbb
# MEDIAWIKI_IMAGE=ghcr.io/<org>/mediawiki
# IMAGE_TAG=sha-abc1234
APP_IMAGE=app
PHPBB_IMAGE=phpbb
MEDIAWIKI_IMAGE=mediawiki
IMAGE_TAG=dev

# PostgreSQL
POSTGRES_DB=myapp
POSTGRES_USER=admin
# openssl rand -base64 24
POSTGRES_PASSWORD=changeme-postgres

# Application
APP_HOST=app
APP_PORT=3000

# phpBB
PHPBB_TABLE_PREFIX=phpbb_
PHPBB_ADMIN_USER=admin
# openssl rand -base64 21  (phpBB max 30 chars)
PHPBB_ADMIN_PASSWORD=changeme-phpbb
PHPBB_ADMIN_EMAIL=admin@example.com
PHPBB_OIDC_CLIENT_ID=phpbb-client
# openssl rand -base64 24
PHPBB_OIDC_CLIENT_SECRET=changeme-phpbb-oidc

# MediaWiki
MEDIAWIKI_ADMIN_USER=admin
# openssl rand -base64 24
MEDIAWIKI_ADMIN_PASSWORD=changeme-mediawiki
# 64-char hex string (openssl rand -hex 32)
MEDIAWIKI_SECRET_KEY=00112233445566778899aabbccddeeff00112233445566778899aabbccddeeff
# 16-char hex string (openssl rand -hex 8)
MEDIAWIKI_UPGRADE_KEY=0011223344556677
MEDIAWIKI_OIDC_CLIENT_ID=mediawiki-client
# openssl rand -base64 24
MEDIAWIKI_OIDC_CLIENT_SECRET=changeme-mediawiki-oidc
