# Site configuration
# Defaults work for local dev (localhost:8443) with zero config.
# For production, set:
#   DOMAIN=vgindex.org
#   HTTPS_PORT=443
DOMAIN=localhost
HTTPS_PORT=8443

# PostgreSQL
POSTGRES_USER=vgindex
POSTGRES_PASSWORD=changeme
POSTGRES_DB=vgindex

# Application
DATABASE_URL=postgres://vgindex:changeme@postgres:5432/vgindex
APP_SECRET_KEY=generate-a-random-64-char-hex-string
APP_PORT=3000

# SMTP (for email verification and password reset)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=noreply@example.com
SMTP_PASSWORD=changeme
SMTP_FROM=noreply@example.com

# OIDC Provider
# In Docker, use the internal service URL so MediaWiki/phpBB can reach
# the token endpoint without TLS. In production, use the public URL.
OIDC_ISSUER_URL=http://app:3000
OIDC_PROVIDER_URL=http://app:3000
OIDC_CLIENT_ID=mediawiki-client
OIDC_CLIENT_SECRET=change-this-secret-mediawiki

# MediaWiki
MEDIAWIKI_SECRET_KEY=change-this-secret-key-in-production
MEDIAWIKI_UPGRADE_KEY=change-this-upgrade-key
MEDIAWIKI_ADMIN_USER=admin
MEDIAWIKI_ADMIN_PASSWORD=ChangeMe!Admin2026
